{
  "manifest_version": 3,
  "name": "LETUS Task Watcher",
  "version": "1.0.3",
  "description": "Organize LETUS assignment deadlines and submission status in your browser.",
  "permissions": [
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://letus.ed.tus.ac.jp/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "LETUS Task Watcher",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}